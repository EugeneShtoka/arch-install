# vim: filetype=neomuttrc

# Account
bind index,pager i noop
macro index,pager i1 '<sync-mailbox><enter-command>source /home/eugene/.config/neomutt/accounts/e.shtoka@gmail.com.muttrc<enter><change-folder>!<enter>;<check-stats>' "switch to e.shtoka@gmail.com"
source /home/eugene/.config/neomutt/accounts/e.shtoka@gmail.com.muttrc

# Theme
source /home/eugene/.config/neomutt/cobalt2.muttrc

# --- Sending ---
set send_charset     = "us-ascii:utf-8"
set smtp_authenticators = "gssapi:login"
set fast_reply                        # skip to compose when replying
set reverse_name                      # reply as whomever it was to
set include                           # include message in replies
set forward_quote                     # include message in forwards
set forward_format   = "Fwd: %s"
set mime_forward     = no             # forward body as text, not attachment
set forward_attachments = yes

# --- Pager ---
set pager_index_lines = 8      # show index context while reading
set pager_context     = 3      # lines of context when scrolling pages
set pager_stop               # don't move to next message at end of pager
set wrap              = 100    # wrap long lines
set tilde                    # show ~ for lines past end of message

# --- Reading ---
set sort             = reverse-date
set rfc2047_parameters = yes          # decode RFC2047 encoded filenames
set mark_old         = no             # unread stays unread until opened
set mail_check       = 60
set sleep_time       = 0              # no pause on info messages
set markers          = no             # no `+` wrap markers
set wait_key         = no             # no "press key to continue" prompts

# --- MIME / attachments ---
set mailcap_path     = $HOME/.config/neomutt/mailcap
set mime_type_query_command = "file --mime-type -b %s"
set fcc_attach                        # save attachments with sent mail
auto_view text/html
alternative_order text/plain text/enriched text/html

# --- Index display ---
set header_cache_backend = "lmdb"
set date_format      = "%d-%m-%y %H:%M"
set hidden_tags      = "inbox,unread,social,important,attachment,signed,encrypted,sent"
set index_format     = "%2C %Z %?X?A& ? %D %-20.20F %-20.20g %-60.60s"

# --- Sidebar ---
set sidebar_visible       = yes
set sidebar_width         = 20
set sidebar_short_path    = yes
set sidebar_next_new_wrap = yes
set mail_check_stats
set sidebar_format = '%D%?F? [%F]?%* %?N?%N/? %?S?%S?'

bind index,pager \Ck sidebar-prev
bind index,pager \Cj sidebar-next
bind index,pager \Co sidebar-open
bind index,pager \Cp sidebar-prev-new
bind index,pager \Cn sidebar-next-new
bind index,pager B  sidebar-toggle-visible

# --- Navigation (vim-style) ---
bind index,pager g    noop
bind index       gg   first-entry
bind index       G    last-entry
bind index       j    next-entry
bind index       k    previous-entry
bind index,pager \Cd  half-down
bind index,pager \Cu  half-up
bind index       l    display-message
bind index       h    noop
bind pager       gg   top
bind pager       G    bottom
bind pager       j    next-line
bind pager       k    previous-line
bind pager       l    view-attachments
bind pager,attach h   exit
bind attach      l    view-mailcap
bind attach      <return> view-mailcap
bind browser     l    select-entry
bind browser     gg   top-page
bind browser     G    bottom-page
macro browser    h    '<change-dir><kill-line>..<enter>' "go to parent folder"

# --- URL handling ---
macro index,pager \cb "<pipe-message>urlscan<enter>" "pick URL to open"

# --- Pager view ---
macro pager V "<view-attachments><search>text/html<enter><view-mailcap><exit>" "open HTML in browser"

# --- Actions ---
bind index,pager S sync-mailbox
bind index,query <space> tag-entry
bind editor      <Tab> complete-query
macro index \Cr "T~U<enter><tag-prefix><clear-flag>N<untag-pattern>.<enter>" "mark all messages as read"
macro index \Cf "<enter-command>unset wait_key<enter><shell-escape>printf 'Enter notmuch search: '; read x; echo \$x >\"${XDG_CACHE_HOME:-$HOME/.cache}/mutt_terms\"<enter><limit>~i \"\`notmuch search --output=messages \$(cat \"${XDG_CACHE_HOME:-$HOME/.cache}/mutt_terms\") | head -n 600 | perl -le '@a=<>;s/\^id:// for@a;$,=\"|\";print@a' | perl -le '@a=<>; chomp@a; s/\\+/\\\\+/g for@a; s/\\$/\\\\\\$/g for@a;print@a' \`\"<enter>" "notmuch search"

# --- Folder navigation ---
macro index,pager gi "<change-folder>$my_q_inbox<enter>"   "go to inbox"
macro index,pager gu "<change-folder>$my_q_unread<enter>"  "go to unread"
macro index,pager gs "<change-folder>$my_q_sent<enter>"    "go to sent"
macro index,pager gd "<change-folder>$my_q_drafts<enter>"  "go to drafts"
macro index,pager gt "<change-folder>$my_q_trash<enter>"   "go to trash"
macro index,pager ga "<change-folder>$my_q_archive<enter>" "go to archive"

# --- Mail actions (custom) ---
macro index,pager d "<modify-labels>+trash -inbox\n<sync-mailbox><shell-escape>~/.scripts/gmi-push.sh<enter><sidebar-open><check-stats>" "delete message"
bind index,pager a noop
macro index,pager a "<modify-labels>-inbox\n<sync-mailbox><shell-escape>~/.scripts/gmi-push.sh<enter><sidebar-open><check-stats>" "archive message"
bind index,pager A create-alias
macro index,pager u "<modify-labels>-trash +inbox\n<sync-mailbox><shell-escape>~/.scripts/gmi-push.sh<enter><sidebar-open><check-stats>" "undelete message"
macro index,pager l "<pipe-message>~/.scripts/mutt-label.sh<enter><sync-mailbox><sidebar-open><check-stats>" "add label"
macro index       R "<sidebar-open>" "refresh inbox"
