# vim: filetype=neomuttrc
source /usr/local/share/mutt-wizard/mutt-wizard.muttrc
source /home/eugene/.config/neomutt/accounts/e.shtoka@gmail.com.muttrc
macro index,pager i1 '<sync-mailbox><enter-command>source /home/eugene/.config/neomutt/accounts/e.shtoka@gmail.com.muttrc<enter><change-folder>!<enter>;<check-stats>' "switch to e.shtoka@gmail.com"
set header_cache_backend = "lmdb"
source /home/eugene/.config/neomutt/cobalt2.muttrc

set wait_key = no
set date_format="%d-%m-%y %H:%M"
set hidden_tags="inbox,unread,social,important,attachment,signed,encrypted"
set index_format="%2C %Z %?X?A& ? %D %-20.20F %-20.20g %-60.60s"

# Override mutt-wizard binds — must be after all sources
unbind index D
unbind index L
unbind index R
macro index,pager D "<modify-labels>+trash -inbox\n<shell-escape>~/.scripts/gmi-push.sh<enter>" "delete message"
macro index,pager L "<pipe-message>~/.scripts/mutt-label.sh<enter><sync-mailbox><change-folder>!<enter>" "add label"
macro index,pager \el "<modify-labels><shell-escape>~/.scripts/gmi-push.sh<enter>" "modify labels manually"
macro index R "<change-folder>!<enter>" "refresh inbox"
