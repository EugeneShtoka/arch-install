# HTML — inline rendering with w3m
text/html; lynx -assume_charset=%{charset} -display_charset=utf-8 -dump -width=100 -nolist %s; nametemplate=%s.html; copiousoutput

# HTML — open in browser
text/html; xdg-open %s; nametemplate=%s.html

# Images
image/*; feh %s

# PDF and other files — delegate to xdg-open
application/pdf; xdg-open %s
application/*; xdg-open %s

# Video / audio
video/*; setsid wezterm start -- vlc %s &; copiousoutput
audio/*; setsid wezterm start -- vlc %s &; copiousoutput

# PGP
application/pgp-encrypted; gpg -d '%s'; copiousoutput
application/pgp-keys; gpg --import '%s'; copiousoutput
