*
.*
!.gitignore
!.gitconfig
!.zshrc
!.zshfn/**
!.xprofile
!.env
!.scripts
!.scripts/**
!.icons
!.icons/**
!dev
!dev/work
!dev/work/.gitconfig
!.config
!.config/zenity-cobalt2
!.config/zenity-cobalt2/**/*
!.config/gtk-3.0
!.config/gtk-3.0/settings.ini
!.config/dbus-1
!.config/dbus-1/services
!.config/dbus-1/services/**/*
!.config/i3
!.config/i3/**/*
!.config/dunst
!.config/dunst/dunstrc
!.config/rimworld
!.config/rimworld/**/*
