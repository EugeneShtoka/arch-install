!.config/copyq/copyq-commands.ini
!.config/copyq/copyq-filter.ini
!.config/copyq/copyq.conf
!.config/copyq/themes
!.config/copyq/themes/*.ini
!.config/autokey
!.config/autokey/data
!.config/autokey/data/**/*
!.config/autokey/autokey.json
!.config/vivaldi
!.config/vivaldi/.gitignore
!.config/vivaldi/styles
!.config/vivaldi/styles/**
!.config/vivaldi/uBlock-filters
!.config/vivaldi/uBlock-filters/**
!.config/systemd
!.config/systemd/user
!.config/systemd/user/start-up-routine.service
!.config/systemd/user/battery-alert.service
!.config/systemd/user/battery-alert.timer
!.config/systemd/user/filemanager1-common.service.d
!.config/systemd/user/filemanager1-common.service.d/display.conf
!.config/qBittorrent
!.config/qBittorrent/qBittorrent.conf
!.config/fontconfig
!.config/fontconfig/fonts.conf
!.config/rofi
!.config/rofi/launchers
!.config/rofi/launchers/type-4
!.config/rofi/launchers/type-4/shared/fonts.rasi
!.config/rofi/launchers/type-4/style-9-no-search.rasi
!.config/rofi/launchers/type-4/style-9-wide.rasi
!.config/rofi/launchers/type-4/style-9-columns.rasi
!.config/nvim
!.config/nvim/**/*
!.config/wezterm
!.config/wezterm/**/*
!.config/yazi
!.config/yazi/**/*
!.config/notmuch
!.config/notmuch/**/*
!.config/neomutt
!.config/neomutt/**/*
!.config/goimapnotify
!.config/goimapnotify/**/*
